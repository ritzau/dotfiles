#!/usr/bin/env bash
set -euo pipefail

# intui-setup-access — Set up local credentials for git host access.
#
# Installs prerequisites, authenticates with the git host, generates an SSH
# key, and registers it. Idempotent — safe to run multiple times.
#
# After running this you can clone repos. Org/repo-level access is granted
# separately by an admin.

info()  { printf '\033[1;34m[info]\033[0m %s\n' "$*"; }
warn()  { printf '\033[1;33m[warn]\033[0m %s\n' "$*" >&2; }
ok()    { printf '\033[1;32m[ok]\033[0m %s\n' "$*"; }
fatal() { printf '\033[1;31m[fatal]\033[0m %s\n' "$*" >&2; exit 1; }

# --- Prerequisites ---

ensure_command() {
  local cmd="$1"
  shift
  if command -v "$cmd" &>/dev/null; then
    ok "$cmd already installed"
    return
  fi

  info "Installing $cmd..."
  if command -v apt-get &>/dev/null; then
    sudo apt-get install -y "$@"
  elif command -v brew &>/dev/null; then
    brew install "$@"
  else
    fatal "Cannot install $cmd — no supported package manager found (apt-get, brew)"
  fi

  command -v "$cmd" &>/dev/null || fatal "$cmd not found after install"
  ok "$cmd installed"
}

install_gh() {
  if command -v gh &>/dev/null; then
    ok "gh already installed"
    return
  fi

  info "Installing gh..."
  if command -v apt-get &>/dev/null; then
    sudo mkdir -p /etc/apt/keyrings
    curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
      | sudo tee /etc/apt/keyrings/githubcli-archive-keyring.gpg >/dev/null
    echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
      | sudo tee /etc/apt/sources.list.d/github-cli.list >/dev/null
    sudo apt-get update -qq
    sudo apt-get install -y gh
  elif command -v brew &>/dev/null; then
    brew install gh
  else
    fatal "Cannot install gh — no supported package manager found"
  fi

  command -v gh &>/dev/null || fatal "gh not found after install"
  ok "gh installed"
}

# --- Authentication ---

setup_gh_auth() {
  if gh auth status &>/dev/null; then
    ok "gh already authenticated"
    return
  fi

  info "Authenticating with GitHub..."
  gh auth login
  ok "gh authenticated"
}

# --- SSH key ---

setup_ssh_key() {
  local key="$HOME/.ssh/id_ed25519"

  if [[ -f "$key" ]]; then
    ok "SSH key already exists: $key"
  else
    info "Generating SSH key..."
    mkdir -p "$HOME/.ssh"
    chmod 700 "$HOME/.ssh"
    ssh-keygen -t ed25519 -f "$key"
    ok "SSH key generated: $key"
  fi

  local pub
  pub=$(awk '{print $2}' "${key}.pub")

  if gh ssh-key list 2>/dev/null | grep -q "$pub"; then
    ok "SSH key already registered with GitHub"
  else
    info "Adding SSH key to GitHub..."
    gh ssh-key add "${key}.pub" --title "$(hostname) $(date +%Y-%m-%d)"
    ok "SSH key registered with GitHub"
  fi
}

# --- Main ---

info "Setting up access..."
printf '\n'

ensure_command curl curl
ensure_command git git
ensure_command ssh openssh-client
install_gh
printf '\n'

setup_gh_auth
printf '\n'

setup_ssh_key
printf '\n'

ok "Access setup complete. You can now clone repos."
