#!/usr/bin/env bash
set -euo pipefail

# intui-setup-access — Set up and verify local credentials for git host access.
#
# Installs prerequisites, authenticates with the git host, generates an SSH
# key, and registers it. Idempotent — safe to run multiple times. Always
# ends with a status report showing what's set up and what remains.
#
# Account naming convention: intui-<first part of email before @>

INTUI_ORG="${INTUI_ORG:-intui}"

# --- Output ---

pass() { printf '\033[32m  ✓ %s\033[0m\n' "$*"; }
fail() { printf '\033[31m  ✗ %s\033[0m\n' "$*"; }
info() { printf '\033[34m  … %s\033[0m\n' "$*"; }
head() { printf '\n\033[1m%s\033[0m\n' "$*"; }

has() { command -v "$1" &>/dev/null; }

# --- Setup steps ---
# Each step tries to fix its concern, then returns 0 (ok) or 1 (still broken).
# Steps must handle being called when already set up (idempotent) and when
# dependencies are missing (graceful skip).

setup_tools() {
  local all_ok=0

  for pair in curl:curl git:git ssh:openssh-client direnv:direnv; do
    local cmd="${pair%%:*}"
    local pkg="${pair##*:}"
    if has "$cmd"; then
      continue
    fi

    info "Installing $cmd..."
    if has apt-get; then
      sudo apt-get install -y "$pkg" >/dev/null 2>&1 || true
    elif has brew; then
      brew install "$pkg" >/dev/null 2>&1 || true
    fi
  done

  # gh needs special repo setup on apt
  if ! has gh; then
    info "Installing gh..."
    if has apt-get; then
      sudo mkdir -p /etc/apt/keyrings
      curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
        | sudo tee /etc/apt/keyrings/githubcli-archive-keyring.gpg >/dev/null 2>&1
      echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
        | sudo tee /etc/apt/sources.list.d/github-cli.list >/dev/null
      sudo apt-get update -qq >/dev/null 2>&1
      sudo apt-get install -y gh >/dev/null 2>&1 || true
    elif has brew; then
      brew install gh >/dev/null 2>&1 || true
    fi
  fi

  return 0
}

setup_auth() {
  if ! has gh; then
    return 1
  fi

  if gh auth status &>/dev/null; then
    return 0
  fi

  info "Authenticating with GitHub..."
  gh auth login || return 1
  return 0
}

setup_ssh_key() {
  local key="$HOME/.ssh/id_ed25519"

  if [[ ! -f "$key" ]]; then
    info "Generating SSH key..."
    mkdir -p "$HOME/.ssh"
    chmod 700 "$HOME/.ssh"
    ssh-keygen -t ed25519 -f "$key" || return 1
  fi

  return 0
}

setup_ssh_registered() {
  local key="$HOME/.ssh/id_ed25519"

  if [[ ! -f "${key}.pub" ]]; then
    return 1
  fi

  if ! has gh || ! gh auth status &>/dev/null; then
    return 1
  fi

  local pub
  pub=$(awk '{print $2}' "${key}.pub")

  if gh ssh-key list 2>/dev/null | grep -q "$pub"; then
    return 0
  fi

  info "Adding SSH key to GitHub..."
  gh ssh-key add "${key}.pub" --title "$(hostname) $(date +%Y-%m-%d)" || return 1
  return 0
}

# --- Status report ---

show_status() {
  local problems=0

  head "Tools"
  for cmd in curl git ssh gh direnv; do
    if has "$cmd"; then
      pass "$cmd"
    else
      fail "$cmd"
      problems=$((problems + 1))
    fi
  done

  head "Authentication"
  if ! has gh; then
    fail "gh not installed — cannot check"
    problems=$((problems + 1))
  elif gh auth status &>/dev/null; then
    local user
    user=$(gh api user --jq .login 2>/dev/null || echo "unknown")
    pass "GitHub: $user"
  else
    fail "gh not authenticated"
    problems=$((problems + 1))
  fi

  head "SSH"
  local key="$HOME/.ssh/id_ed25519"
  if [[ -f "$key" ]]; then
    pass "Key exists: $key"
  else
    fail "No key at $key"
    problems=$((problems + 1))
  fi

  if [[ -f "${key}.pub" ]] && has gh && gh auth status &>/dev/null; then
    local pub
    pub=$(awk '{print $2}' "${key}.pub")
    if gh ssh-key list 2>/dev/null | grep -q "$pub"; then
      pass "Key registered with GitHub"
    else
      fail "Key not registered with GitHub"
      problems=$((problems + 1))
    fi
  elif [[ -f "${key}.pub" ]]; then
    fail "Key registration — cannot check (gh not authenticated)"
    problems=$((problems + 1))
  fi

  head "Organization"
  if has gh && gh auth status &>/dev/null; then
    local login
    login=$(gh api user --jq .login 2>/dev/null || echo "")
    if [[ -n "$login" ]] && gh api "orgs/$INTUI_ORG/memberships/$login" &>/dev/null 2>&1; then
      pass "Member of $INTUI_ORG"
    else
      fail "Not a member of $INTUI_ORG — ask an admin"
      problems=$((problems + 1))
    fi
  else
    fail "Org membership — cannot check (gh not authenticated)"
    problems=$((problems + 1))
  fi

  head "Account"
  local email
  email=$(gh api user --jq .email 2>/dev/null || git config --global user.email 2>/dev/null || true)
  if [[ -n "$email" && "$email" != "null" ]]; then
    local local_part="${email%%@*}"
    local expected="${INTUI_ORG}-${local_part}"
    local current
    current=$(whoami)
    if [[ "$current" == "$expected" ]]; then
      pass "Account name: $current"
    else
      info "Account name: $current (convention: $expected)"
    fi
  else
    info "Account name: $(whoami) (cannot determine email for convention check)"
  fi

  printf '\n'
  if (( problems == 0 )); then
    pass "All good. You can clone repos."
  else
    fail "$problems issue(s) remaining"
  fi
  printf '\n'

  return "$problems"
}

# --- Main ---

setup_tools
setup_auth || true
setup_ssh_key || true
setup_ssh_registered || true

show_status
